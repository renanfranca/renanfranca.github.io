# Optional Docker proxy settings for corporate networks.
# Leave empty or do not copy this file when not on corporate network.

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1

# Jekyll network behavior:
# Keep bind host as 0.0.0.0 in Docker and restrict exposure using JEKYLL_PUBLISH_IP.
JEKYLL_BIND_HOST=0.0.0.0
JEKYLL_PUBLISH_IP=127.0.0.1
JEKYLL_PORT=4000
LIVERELOAD_PORT=35729

# Preferred browser URL host in this environment (documentation only).
JEKYLL_BROWSER_HOST=localhost
